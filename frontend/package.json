{
  "name": "mygarage-frontend",
  "private": true,
  "version": "3.0.0-rc1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit",
    "validate:translations": "bun run scripts/validate-translations.ts && bun run scripts/validate-i18n-usage.ts && bun run scripts/validate-hardcoded-strings.ts && bun run scripts/validate-reachability.ts",
    "validate:reachability": "bun run scripts/validate-reachability.ts",
    "validate:i18n-usage": "bun run scripts/validate-i18n-usage.ts",
    "validate:hardcoded-strings": "bun run scripts/validate-hardcoded-strings.ts",
    "generate:translation-status": "bun run scripts/generate-translation-status.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "generate:schema": "cd ../backend && PYTHONPATH=. uv run python scripts/export_openapi.py ../frontend/src/types/openapi.json",
    "generate:types": "bunx openapi-typescript src/types/openapi.json -o src/types/api.generated.ts",
    "generate:api": "bun run generate:schema && bun run generate:types",
    "check:api-freshness": "bun run generate:api && git diff --exit-code src/types/openapi.json src/types/api.generated.ts"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@hookform/resolvers": "^5.4.0",
    "@schedule-x/calendar": "^4.6.1",
    "@schedule-x/calendar-controls": "^4.6.1",
    "@schedule-x/events-service": "^4.6.1",
    "@schedule-x/react": "^4.1.0",
    "@schedule-x/theme-default": "^4.6.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "react-i18next": "^17.0.10",
    "react-is": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "temporal-polyfill": "^1.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "postcss": "^8.5.15",
    "undici": "^7.28.0",
    "form-data": "^4.0.6",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.7"
  }
}
